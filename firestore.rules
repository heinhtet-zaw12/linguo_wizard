rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Rate limiter subcollection — owner-only read/write.
      match /rateLimits/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Gamification subcollections — owner-only read/write.
      match /scenarios/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /conversations/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /badges/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /srs_items/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /mistakes/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    // Public scenarios collection — unauthenticated reads allowed.
    // Writes restricted to admin users only (admin flag on auth token).
    match /scenarios/{scenarioId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    match /rate_limits/{docId} {
      allow read, write: if true;
    }
  }
}